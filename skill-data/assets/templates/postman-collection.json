{
  "info": {
    "name": "{EntityName} API Collection",
    "description": "{EntityName}接口测试集合",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "创建{EntityName}",
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  // TODO: 添加请求字段\n  \"field1\": \"value1\",\n  \"field2\": \"value2\"\n}"
        },
        "url": {
          "raw": "http://localhost:8080/api/v1/{moduleName}",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8080",
          "path": ["api", "v1", "{moduleName}"]
        },
        "description": "创建新的{EntityName}"
      }
    },
    {
      "name": "查询{EntityName}",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "http://localhost:8080/api/v1/{moduleName}/1",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8080",
          "path": ["api", "v1", "{moduleName}", "1"]
        },
        "description": "根据ID查询{EntityName}详情"
      }
    },
    {
      "name": "更新{EntityName}",
      "request": {
        "method": "PUT",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  // TODO: 添加更新字段\n  \"field1\": \"newValue1\"\n}"
        },
        "url": {
          "raw": "http://localhost:8080/api/v1/{moduleName}/1",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8080",
          "path": ["api", "v1", "{moduleName}", "1"]
        },
        "description": "更新{EntityName}信息"
      }
    },
    {
      "name": "删除{EntityName}",
      "request": {
        "method": "DELETE",
        "header": [],
        "url": {
          "raw": "http://localhost:8080/api/v1/{moduleName}/1",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8080",
          "path": ["api", "v1", "{moduleName}", "1"]
        },
        "description": "删除{EntityName}"
      }
    },
    {
      "name": "查询{EntityName}列表",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "http://localhost:8080/api/v1/{moduleName}?current=1&size=10",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8080",
          "path": ["api", "v1", "{moduleName}"],
          "query": [
            {
              "key": "current",
              "value": "1"
            },
            {
              "key": "size",
              "value": "10"
            }
          ]
        },
        "description": "分页查询{EntityName}列表"
      }
    }
  ]
}
